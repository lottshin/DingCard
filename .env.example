# 叮卡 · Docker Compose 环境变量模板
#
# 用法:  cp .env.example .env  然后填好下面的值(至少改 JWT_SECRET)。
# docker compose 和 Vite 都会读取同目录的 .env。Compose 相关变量列在下面;
# 后端还有更多可调项(见 server/.env.example),Docker 部署一般用默认值即可。
#
# ⚠️ .env 含密钥,已被 .gitignore 忽略,切勿提交。

# ---- 必填 ----------------------------------------------------------------
# JWT 签名密钥。必须是一段足够随机的长字符串,泄露=任何人可伪造登录。
# 生成一个(任选其一):
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---- 前端存储模式 --------------------------------------------------------
# 留空 = 默认 LocalStore(浏览器本地、可离线)；直连独立后端时填其公开地址。
# Docker Compose 构建会固定注入同源 `/`，不使用这里的值。
VITE_API_BASE=

# ---- 可选(有默认值,按需覆盖)--------------------------------------------
# 登录令牌有效期。支持 7d / 24h / 30m 等写法。
JWT_EXPIRY=7d

# 每分钟全局请求上限与认证路由上限。生产默认分别为 300 / 20。
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# 每个用户的图片存储配额(字节)。默认 500MB。0 = 不限制。
USER_QUOTA_BYTES=524288000

# 图片租约时长(毫秒)。默认 24 小时；仅租约过期且未被草稿引用的图片会被回收。
IMAGE_LEASE_MS=86400000

# 单张图片上传大小上限(字节)。默认 6MB。
# 改这里也要同步改 deploy/nginx.conf 的 client_max_body_size,否则大图会被 Nginx 先挡。
MAX_UPLOAD_BYTES=6291456

# 宿主机端口 → 容器内 Nginx 的 80。首次测试可用 8080。
# 接入宿主机反代/负载均衡后改为 127.0.0.1:8080,避免绕过 HTTPS 直接访问。
# 见 docs/deployment.md。
WEB_PORT=8080
