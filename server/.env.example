# 叮卡后端 · 环境变量模板(非 Docker 直跑)
#
# 用法:  cp .env.example .env  并填好值。仅当你在宿主机上直接 `npm start`
# 时需要;用 Docker Compose 部署的话,配根目录的 .env 即可(见 ../.env.example)。
#
# ⚠️ .env 含密钥,已被 .gitignore 忽略,切勿提交。

# ---- 必填(生产)----------------------------------------------------------
# JWT 签名密钥。生产环境必须设置,否则拒绝启动。生成:
#   openssl rand -hex 32
JWT_SECRET=

# ---- 运行 ----------------------------------------------------------------
# 生产设为 production(会强制校验 JWT_SECRET);开发留空即可。
NODE_ENV=production
# 监听地址与端口。放在 Nginx 后面时用 127.0.0.1 只听本机。
HOST=127.0.0.1
PORT=3000

# ---- 数据位置 ------------------------------------------------------------
# 数据根目录。SQLite 库与 uploads 默认都放这下面。
DATA_DIR=./data
# 如需单独指定,可覆盖(留空则用 DATA_DIR 推导):
#   DB_PATH=./data/data.db
#   UPLOADS_DIR=./data/uploads

# 图片对外的 URL 前缀。Nginx 把它映射到 UPLOADS_DIR。
UPLOADS_PUBLIC_PATH=/uploads

# ---- 认证 ----------------------------------------------------------------
JWT_EXPIRY=7d
# bcrypt 代价因子。越大越慢越安全,10~12 之间较合适。
BCRYPT_COST=12

# ---- 限额 ----------------------------------------------------------------
# 每用户图片配额(字节),默认 500MB,0 = 不限。
USER_QUOTA_BYTES=524288000
# 单张上传上限(字节),默认 6MB。
MAX_UPLOAD_BYTES=6291456

# ---- CORS ----------------------------------------------------------------
# 同源部署(前端与 /api 经同一域名)时留空即可。
# 前后端分离域名时,填前端来源,多个用逗号分隔:
#   CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=
