# 前端构建镜像的构建上下文瘦身。只有 build 前端产物需要的东西该进上下文。

# 依赖:镜像里用 npm ci 重装,不打包本地的。
node_modules

# 后端有自己的镜像和构建上下文,前端镜像不需要。
server

# 构建产物 / 缓存
dist
*.tsbuildinfo

# 测试与其产物(不影响前端产物)
e2e
e2e-integration
test-results
playwright-report
playwright.config.ts
playwright.integration.config.ts

# git / 工作树 / 编辑器 / 原型草稿
.git
.gitignore
.worktrees
.vscode
.idea
.superpowers

# 文档
docs
*.md

# 本地环境文件(密钥绝不进镜像)
.env
.env.local
.env.*.local

# 日志与系统文件
*.log
.DS_Store
Thumbs.db
